@* Views/SingleClassPage/Sections/_HeaderSection.cshtml *@
@model VIVEcms.Models.Pages.SingleClassPage
@using EPiServer.Web.Mvc.Html

<div class="elementor-container elementor-column-gap-default">

@* ===== COLUMN 1: CONTENT ===== *@
<div class="elementor-column elementor-col-33 elementor-top-column elementor-element elementor-element-12a303c" data-element_type="column" data-id="12a303c" data-settings='{"vive_ext_link_sidemenu":"false","vive_ext_link_fullmenu":"false","vive_ext_is_sticky":"false","vive_ext_is_scrollme":"false","vive_ext_is_smoove":"false","vive_ext_is_parallax_mouse":"false","vive_ext_is_infinite":"false","vive_ext_is_fadeout_animation":"false"}'>
    <div class="elementor-widget-wrap elementor-element-populated">

        @* Heading Line 1 *@
        <div class="elementor-element elementor-element-6ab11ab elementor-widget elementor-widget-vive-animated-text" data-element_type="widget" data-id="6ab11ab" data-settings='{"vive_ext_link_sidemenu":"false","vive_ext_link_fullmenu":"false","vive_ext_is_sticky":"false","vive_ext_is_scrollme":"false","vive_ext_is_smoove":"false","vive_ext_is_parallax_mouse":"false","vive_ext_is_infinite":"false","vive_ext_is_fadeout_animation":"false"}' data-widget_type="vive-animated-text.default">
            <div class="elementor-widget-container">
                <div class="themegoods-animated-text text-alignment-left transition-bottom overflow-hidden" data-delimiter="sentence" data-transition="100" data-transition-delay="0" data-transition-duration="800">
                    <h2 @Html.EditAttributes(x => x.HeaderHeading1)>
                        @Model.HeaderHeading1
                    </h2>
                </div>
            </div>
        </div>

        @* Heading Line 2 — italic *@
        <div class="elementor-element elementor-element-7053001 elementor-widget elementor-widget-vive-animated-text" data-element_type="widget" data-id="7053001" data-settings='{"vive_ext_link_sidemenu":"false","vive_ext_link_fullmenu":"false","vive_ext_is_sticky":"false","vive_ext_is_scrollme":"false","vive_ext_is_smoove":"false","vive_ext_is_parallax_mouse":"false","vive_ext_is_infinite":"false","vive_ext_is_fadeout_animation":"false"}' data-widget_type="vive-animated-text.default">
            <div class="elementor-widget-container">
                <div class="themegoods-animated-text text-alignment-left transition-bottom overflow-hidden" data-delimiter="sentence" data-transition="100" data-transition-delay="50" data-transition-duration="800">
                    <h1 @Html.EditAttributes(x => x.HeaderHeading2)>
                        <i>@Model.HeaderHeading2</i>
                    </h1>
                </div>
            </div>
        </div>

        @* Heading Line 3 *@
        <div class="elementor-element elementor-element-7dfd8ac elementor-widget elementor-widget-vive-animated-text" data-element_type="widget" data-id="7dfd8ac" data-settings='{"vive_ext_link_sidemenu":"false","vive_ext_link_fullmenu":"false","vive_ext_is_sticky":"false","vive_ext_is_scrollme":"false","vive_ext_is_smoove":"false","vive_ext_is_parallax_mouse":"false","vive_ext_is_infinite":"false","vive_ext_is_fadeout_animation":"false"}' data-widget_type="vive-animated-text.default">
            <div class="elementor-widget-container">
                <div class="themegoods-animated-text text-alignment-left transition-bottom overflow-hidden" data-delimiter="sentence" data-transition="100" data-transition-delay="100" data-transition-duration="800">
                    <h1 @Html.EditAttributes(x => x.HeaderHeading3)>
                        @Model.HeaderHeading3
                    </h1>
                </div>
            </div>
        </div>

        @* Button *@
        @if (!string.IsNullOrWhiteSpace(Model.HeaderButtonText))
        {
            <div class="elementor-element elementor-element-438a809 elementor-widget__width-auto animated-fast elementor-invisible elementor-widget elementor-widget-button" data-element_type="widget" data-id="438a809" data-settings='{"_animation":"fadeIn","_animation_delay":400,"vive_ext_link_sidemenu":"false","vive_ext_link_fullmenu":"false","vive_ext_is_sticky":"false","vive_ext_is_scrollme":"false","vive_ext_is_parallax_mouse":"false","vive_ext_is_infinite":"false","vive_ext_is_fadeout_animation":"false"}' data-widget_type="button.default">
                <div class="elementor-widget-container">
                    <div class="elementor-button-wrapper">
                        <a class="elementor-button elementor-button-link elementor-size-sm elementor-animation-rotate"
                           href="@(string.IsNullOrWhiteSpace(Model.HeaderButtonUrl) ? "#" : Model.HeaderButtonUrl)">
                            <span class="elementor-button-content-wrapper">
                                <span class="elementor-button-text"
                                      @Html.EditAttributes(x => x.HeaderButtonText)>
                                    @Model.HeaderButtonText
                                </span>
                            </span>
                        </a>
                    </div>
                </div>
            </div>
        }

        @* Video Link *@
        @if (!string.IsNullOrWhiteSpace(Model.HeaderVideoUrl))
        {
            <div class="elementor-element elementor-element-6cd58aa elementor-icon-list--layout-inline animated-fast elementor-widget__width-auto elementor-hidden-mobile elementor-list-item-link-full_width elementor-invisible elementor-widget elementor-widget-icon-list" data-element_type="widget" data-id="6cd58aa" data-settings='{"_animation":"fadeIn","_animation_delay":400,"vive_ext_link_sidemenu":"false","vive_ext_link_fullmenu":"false","vive_ext_is_sticky":"false","vive_ext_is_scrollme":"false","vive_ext_is_parallax_mouse":"false","vive_ext_is_infinite":"false","vive_ext_is_fadeout_animation":"false"}' data-widget_type="icon-list.default">
                <div class="elementor-widget-container">
                    <link href="css/widget-icon-list.min.css" rel="stylesheet" />
                    <ul class="elementor-icon-list-items elementor-inline-items">
                        <li class="elementor-icon-list-item elementor-inline-item">
                            <a class="youtube-lightbox"
                               href="@Model.HeaderVideoUrl"
                               rel="nofollow">
                                <span class="elementor-icon-list-icon">
                                    <i aria-hidden="true" class="far fa-play-circle"></i>
                                </span>
                                <span class="elementor-icon-list-text"
                                      @Html.EditAttributes(x => x.HeaderVideoText)>
                                    @Model.HeaderVideoText
                                </span>
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        }

    </div>
</div>

@* ===== COLUMN 2: EMPTY ===== *@
<div class="elementor-column elementor-col-66 elementor-top-column elementor-element elementor-element-5e4b5ce" data-element_type="column" data-id="5e4b5ce" data-settings='{"vive_ext_link_sidemenu":"false","vive_ext_link_fullmenu":"false","vive_ext_is_sticky":"false","vive_ext_is_scrollme":"false","vive_ext_is_smoove":"false","vive_ext_is_parallax_mouse":"false","vive_ext_is_infinite":"false","vive_ext_is_fadeout_animation":"false"}'>
    <div class="elementor-widget-wrap"></div>
</div>

</div>