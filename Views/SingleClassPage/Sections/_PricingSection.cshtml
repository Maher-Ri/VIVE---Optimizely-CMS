@* Views/SingleClassPage/Sections/_PricingSection.cshtml *@
@model VIVEcms.Models.Pages.SingleClassPage
@using EPiServer.Core
@using EPiServer.Web.Mvc.Html
@inject VIVEcms.Services.IImageService ImageService

@{
var features = !string.IsNullOrWhiteSpace(Model.CardFeatures)
    ? Model.CardFeatures.Split(',').Select(f => f.Trim()).Where(f => !string.IsNullOrEmpty(f)).ToList()
    : new List<string>();
}

<div class="elementor-container elementor-column-gap-default">

@* ===== COLUMN 1: LEFT IMAGE ===== *@
<div class="elementor-column elementor-col-66 elementor-top-column elementor-element elementor-element-926ef6e" data-element_type="column" data-id="926ef6e" data-settings='{"background_background":"classic","vive_ext_link_sidemenu":"false","vive_ext_link_fullmenu":"false","vive_ext_is_sticky":"false","vive_ext_is_scrollme":"false","vive_ext_is_smoove":"false","vive_ext_is_parallax_mouse":"false","vive_ext_is_infinite":"false","vive_ext_is_fadeout_animation":"false"}'>
    <div class="elementor-widget-wrap elementor-element-populated">
        <div class="elementor-element elementor-element-ee90cd5 mobile-static elementor-widget__width-initial elementor-absolute elementor-widget elementor-widget-image" data-element_type="widget" data-id="ee90cd5" data-settings='{"_position":"absolute","vive_image_is_animation":"false","vive_ext_link_sidemenu":"false","vive_ext_link_fullmenu":"false","vive_ext_is_sticky":"false","vive_ext_is_scrollme":"false","vive_ext_is_smoove":"false","vive_ext_is_parallax_mouse":"false","vive_ext_is_infinite":"false","vive_ext_is_fadeout_animation":"false"}' data-widget_type="image.default"
             @Html.EditAttributes(x => x.PricingLeftImage)>
            <div class="elementor-widget-container">
                @if (!ContentReference.IsNullOrEmpty(Model.PricingLeftImage))
                {
                    <img alt="@(Model.PricingLeftImage != null ? ImageService.GetAltText(Model.PricingLeftImage) : "")"
                         class="attachment-full size-full wp-image-1878"
                         decoding="async"
                         fetchpriority="high"
                         height="1070"
                         src="@Url.ContentUrl(Model.PricingLeftImage)"
                         width="1600" />
                }
            </div>
        </div>
    </div>
</div>

@* ===== COLUMN 2: RIGHT CONTENT ===== *@
<div class="elementor-column elementor-col-33 elementor-top-column elementor-element elementor-element-7f0d300" data-element_type="column" data-id="7f0d300" data-settings='{"vive_ext_link_sidemenu":"false","vive_ext_link_fullmenu":"false","vive_ext_is_sticky":"false","vive_ext_is_scrollme":"false","vive_ext_is_smoove":"false","vive_ext_is_parallax_mouse":"false","vive_ext_is_infinite":"false","vive_ext_is_fadeout_animation":"false"}'>
    <div class="elementor-widget-wrap elementor-element-populated">

        @* Heading 1 *@
        <div class="elementor-element elementor-element-83b09a2 elementor-widget elementor-widget-vive-animated-text" data-element_type="widget" data-id="83b09a2" data-settings='{"vive_ext_link_sidemenu":"false","vive_ext_link_fullmenu":"false","vive_ext_is_sticky":"false","vive_ext_is_scrollme":"false","vive_ext_is_smoove":"false","vive_ext_is_parallax_mouse":"false","vive_ext_is_infinite":"false","vive_ext_is_fadeout_animation":"false"}' data-widget_type="vive-animated-text.default">
            <div class="elementor-widget-container">
                <div class="themegoods-animated-text text-alignment-left transition-bottom overflow-hidden" data-delimiter="sentence" data-transition="100" data-transition-delay="0" data-transition-duration="800">
                    <h2 @Html.EditAttributes(x => x.PricingHeading1)>
                        @Model.PricingHeading1
                    </h2>
                </div>
            </div>
        </div>

        @* Heading 2 *@
        <div class="elementor-element elementor-element-ed2a4a2 elementor-widget elementor-widget-vive-animated-text" data-element_type="widget" data-id="ed2a4a2" data-settings='{"vive_ext_link_sidemenu":"false","vive_ext_link_fullmenu":"false","vive_ext_is_sticky":"false","vive_ext_is_scrollme":"false","vive_ext_is_smoove":"false","vive_ext_is_parallax_mouse":"false","vive_ext_is_infinite":"false","vive_ext_is_fadeout_animation":"false"}' data-widget_type="vive-animated-text.default">
            <div class="elementor-widget-container">
                <div class="themegoods-animated-text text-alignment-left transition-bottom overflow-hidden" data-delimiter="sentence" data-transition="100" data-transition-delay="0" data-transition-duration="800">
                    <h2 @Html.EditAttributes(x => x.PricingHeading2)>
                        @Model.PricingHeading2
                    </h2>
                </div>
            </div>
        </div>

        @* ===== PRICING CARD ===== *@
        <section class="elementor-section elementor-inner-section elementor-element elementor-element-b443c3b elementor-section-boxed elementor-section-height-default elementor-section-height-default" data-element_type="section" data-id="b443c3b" data-settings='{"vive_ext_is_background_parallax":"false","vive_ext_is_background_on_scroll":"false"}'>
            <div class="elementor-container elementor-column-gap-default">

