@* Views/SingleProductPage/Sections/_SummarySection.cshtml *@
@* TODO: convert to dynamic — replace hardcoded values with model properties *@

<div style="display:flex;flex-direction:column;gap:20px;padding-top:8px;">

    @* badge + rating *@
    <div style="display:flex;align-items:center;gap:10px;">
        <span style="background:#edf7ed;color:#2e7d32;font-size:0.72rem;font-weight:700;
                     letter-spacing:.08em;text-transform:uppercase;padding:4px 12px;
                     border-radius:20px;">In Stock</span>
        <span style="color:#f5a623;font-size:0.84rem;">★★★★★</span>
        <span style="color:#aaa;font-size:0.78rem;">(48 reviews)</span>
    </div>

    @* title *@
    <h1 style="margin:0;font-size:2rem;font-weight:800;color:#111;
               line-height:1.2;letter-spacing:-.02em;">
        Performance Training Sneakers
    </h1>

    @* price *@
    <div style="display:flex;align-items:baseline;gap:10px;">
        <span style="font-size:1.7rem;font-weight:800;color:#e94f2e;">
            $129<sup style="font-size:1rem;font-weight:700;">.99</sup>
        </span>
        <span style="font-size:1rem;color:#bbb;text-decoration:line-through;">$179.99</span>
        <span style="background:#fff0ee;color:#e94f2e;font-size:0.72rem;font-weight:700;
                     padding:3px 9px;border-radius:4px;letter-spacing:.04em;">SAVE 28%</span>
    </div>

    @* short description *@
    <p style="margin:0;color:#555;font-size:0.93rem;line-height:1.75;">
        Ultra-lightweight training shoe engineered for high-intensity workouts.
        Breathable mesh upper, responsive foam midsole, and grippy rubber outsole
        keep you stable through every rep.
    </p>

    <hr style="border:none;border-top:1px solid #eee;margin:0;" />

    @* size selector *@
    <div>
        <div style="font-size:0.78rem;font-weight:700;text-transform:uppercase;
                    letter-spacing:.1em;color:#111;margin-bottom:10px;">
            Choose a size
        </div>
        <div id="sp-sizes" style="display:flex;gap:8px;flex-wrap:wrap;">
            <button onclick="spSize(this)"
                    style="min-width:52px;padding:9px 16px;border:1.5px solid #111;
                           border-radius:8px;background:#111;color:#fff;
                           font-size:0.86rem;font-weight:700;cursor:pointer;">XS</button>
            <button onclick="spSize(this)"
                    style="min-width:52px;padding:9px 16px;border:1.5px solid #ddd;
                           border-radius:8px;background:#fff;color:#333;
                           font-size:0.86rem;font-weight:700;cursor:pointer;">S</button>
            <button onclick="spSize(this)"
                    style="min-width:52px;padding:9px 16px;border:1.5px solid #ddd;
                           border-radius:8px;background:#fff;color:#333;
                           font-size:0.86rem;font-weight:700;cursor:pointer;">M</button>
            <button onclick="spSize(this)"
                    style="min-width:52px;padding:9px 16px;border:1.5px solid #ddd;
                           border-radius:8px;background:#fff;color:#333;
                           font-size:0.86rem;font-weight:700;cursor:pointer;">L</button>
            <button onclick="spSize(this)"
                    style="min-width:52px;padding:9px 16px;border:1.5px solid #ddd;
                           border-radius:8px;background:#fff;color:#333;
                           font-size:0.86rem;font-weight:700;cursor:pointer;">XL</button>
            <button onclick="spSize(this)"
                    style="min-width:52px;padding:9px 16px;border:1.5px solid #ddd;
                           border-radius:8px;background:#fff;color:#333;
                           font-size:0.86rem;font-weight:700;cursor:pointer;">XXL</button>
        </div>
    </div>

    @* cart row *@
    <div style="display:flex;gap:12px;align-items:stretch;">

        @* qty stepper *@
        <div style="display:flex;align-items:center;border:1.5px solid #ddd;
                    border-radius:10px;overflow:hidden;background:#fff;">
            <button onclick="spQty(-1)"
                    style="width:44px;height:52px;background:none;border:none;
                           font-size:1.4rem;line-height:1;cursor:pointer;color:#111;">−</button>
            <input id="sp-qty" type="number" value="1" min="1"
                   style="width:50px;height:52px;border:none;
                          border-left:1.5px solid #ddd;border-right:1.5px solid #ddd;
                          text-align:center;font-size:1rem;font-weight:700;color:#111;
                          background:#fff;-moz-appearance:textfield;" />
            <button onclick="spQty(1)"
                    style="width:44px;height:52px;background:none;border:none;
                           font-size:1.4rem;line-height:1;cursor:pointer;color:#111;">+</button>
        </div>

        @* add to cart *@
        <button onmouseover="this.style.background='#e94f2e'"
                onmouseout="this.style.background='#111'"
                style="flex:1;height:52px;background:#111;color:#fff;border:none;
                       border-radius:10px;font-size:0.86rem;font-weight:800;
                       text-transform:uppercase;letter-spacing:.1em;cursor:pointer;
                       transition:background .2s;">
            Add to Cart
        </button>

    </div>

    <hr style="border:none;border-top:1px solid #eee;margin:0;" />

    @* meta *@
    <div style="display:flex;flex-direction:column;gap:7px;font-size:0.84rem;">
        <div style="display:flex;gap:10px;">
            <span style="font-weight:700;color:#444;min-width:82px;text-transform:uppercase;
                         font-size:0.74rem;letter-spacing:.06em;">SKU</span>
            <span style="color:#666;">PTR-2024-BLK</span>
        </div>
        <div style="display:flex;gap:10px;">
            <span style="font-weight:700;color:#444;min-width:82px;text-transform:uppercase;
                         font-size:0.74rem;letter-spacing:.06em;">Category</span>
            <span style="color:#666;">Sneakers, Sport</span>
        </div>
        <div style="display:flex;gap:10px;">
            <span style="font-weight:700;color:#444;min-width:82px;text-transform:uppercase;
                         font-size:0.74rem;letter-spacing:.06em;">Tags</span>
            <span style="color:#666;">training, performance, sport</span>
        </div>
    </div>

</div>

<script>
    function spSize(el) {
        document.querySelectorAll('#sp-sizes button').forEach(function (b) {
            b.style.borderColor = '#ddd';
            b.style.background = '#fff';
            b.style.color = '#333';
        });
        el.style.borderColor = '#111';
        el.style.background = '#111';
        el.style.color = '#fff';
    }
    function spQty(delta) {
        var inp = document.getElementById('sp-qty');
        inp.value = Math.max(1, (parseInt(inp.value) || 1) + delta);
    }
</script>
