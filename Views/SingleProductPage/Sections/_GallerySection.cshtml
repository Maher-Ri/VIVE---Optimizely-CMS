@* Views/SingleProductPage/Sections/_GallerySection.cshtml *@
@* TODO: convert to dynamic — replace hardcoded image paths with model properties *@

<div id="sp-gallery" style="position:sticky;top:24px;display:flex;flex-direction:column;gap:12px;">

    @* ── main image ── *@
    <div style="width:100%;aspect-ratio:4/5;border-radius:20px;overflow:hidden;background:#f2f2f2;">
        <img id="sp-main-img"
             src="/images/portrait-of-female-boxer-2021-04-02-20-48-34-utc-600x600.jpg"
             alt="Product image"
             style="width:100%;height:100%;object-fit:cover;display:block;transition:opacity .2s ease;" />
    </div>

    @* ── thumbnail strip ── *@
    <div style="display:flex;gap:8px;">

        <div onclick="spThumb(this,'/images/portrait-of-female-boxer-2021-04-02-20-48-34-utc-600x600.jpg')"
             style="width:74px;height:74px;border-radius:10px;overflow:hidden;border:2px solid #111;cursor:pointer;flex-shrink:0;background:#f2f2f2;transition:border-color .18s;">
            <img src="/images/portrait-of-female-boxer-2021-04-02-20-48-34-utc-150x150.jpg"
                 alt="View 1"
                 style="width:100%;height:100%;object-fit:cover;display:block;pointer-events:none;" />
        </div>

        <div onclick="spThumb(this,'/images/woman-athlete-exercising-with-medicine-ball-PYB74ZY-600x600.jpg')"
             style="width:74px;height:74px;border-radius:10px;overflow:hidden;border:2px solid #e0e0e0;cursor:pointer;flex-shrink:0;background:#f2f2f2;transition:border-color .18s;">
            <img src="/images/woman-athlete-exercising-with-medicine-ball-PYB74ZY-150x150.jpg"
                 alt="View 2"
                 style="width:100%;height:100%;object-fit:cover;display:block;pointer-events:none;" />
        </div>

        <div onclick="spThumb(this,'/images/attractive-woman-drinking-water-from-sport-bottle-2021-04-06-18-09-19-utc-600x600.jpg')"
             style="width:74px;height:74px;border-radius:10px;overflow:hidden;border:2px solid #e0e0e0;cursor:pointer;flex-shrink:0;background:#f2f2f2;transition:border-color .18s;">
            <img src="/images/attractive-woman-drinking-water-from-sport-bottle-2021-04-06-18-09-19-utc-150x150.jpg"
                 alt="View 3"
                 style="width:100%;height:100%;object-fit:cover;display:block;pointer-events:none;" />
        </div>

        <div onclick="spThumb(this,'/images/pretty-cheerful-sporty-girl-with-yoga-mat-talking-2021-04-05-23-18-06-utc-600x600.jpg')"
             style="width:74px;height:74px;border-radius:10px;overflow:hidden;border:2px solid #e0e0e0;cursor:pointer;flex-shrink:0;background:#f2f2f2;transition:border-color .18s;">
            <img src="/images/pretty-cheerful-sporty-girl-with-yoga-mat-talking-2021-04-05-23-18-06-utc-150x150.jpg"
                 alt="View 4"
                 style="width:100%;height:100%;object-fit:cover;display:block;pointer-events:none;" />
        </div>

    </div>

</div>

<script>
    function spThumb(el, src) {
        document.getElementById('sp-main-img').src = src;
        document.querySelectorAll('#sp-gallery > div:last-child > div').forEach(function (t) {
            t.style.borderColor = '#e0e0e0';
        });
        el.style.borderColor = '#111';
    }
</script>