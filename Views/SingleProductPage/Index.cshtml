@* Views/SingleProductPage/Index.cshtml *@
@model VIVEcms.Models.ViewModels.PageViewModel<VIVEcms.Models.Pages.SingleProductPage>

@* ===== outer page wrapper ===== *@
<div style="max-width:1280px;margin:0 auto;padding:48px 28px 96px;">

    @* ===== hero: gallery + summary side by side ===== *@
    <div class="sp-hero-grid" style="display:grid;grid-template-columns:52% 1fr;gap:56px;align-items:start;margin-bottom:72px;">

        @await Html.PartialAsync("~/Views/SingleProductPage/Sections/_GallerySection.cshtml", Model.CurrentPage)

        @await Html.PartialAsync("~/Views/SingleProductPage/Sections/_SummarySection.cshtml", Model.CurrentPage)

    </div>

    @* ===== tabs ===== *@
    @await Html.PartialAsync("~/Views/SingleProductPage/Sections/_TabsSection.cshtml", Model.CurrentPage)

    @* ===== related products ===== *@
    @await Html.PartialAsync("~/Views/SingleProductPage/Sections/_RelatedSection.cshtml", Model.CurrentPage)

</div>

@* responsive collapse at ≤900px *@
<style>
    @@media (max-width: 900px) {
        .sp-hero-grid { grid-template-columns: 1fr !important; gap: 28px !important; }
    }
</style>
