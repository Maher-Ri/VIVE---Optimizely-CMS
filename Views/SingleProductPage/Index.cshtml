@* Views/SingleProductPage/Index.cshtml *@
@model VIVEcms.Models.ViewModels.PageViewModel<VIVEcms.Models.Pages.SingleProductPage>

<style>
    .sp-page {
        max-width: 1240px;
        margin: 0 auto;
        padding: 48px 24px 100px;
    }
    .sp-hero {
        display: grid;
        grid-template-columns: 55% 1fr;
        gap: 60px;
        align-items: start;
        margin-bottom: 72px;
    }
    @@media (max-width: 900px) {
        .sp-hero {
            grid-template-columns: 1fr;
            gap: 32px;
        }
    }
</style>

<div class="sp-page">
    <div class="sp-hero">
        @* SECTION 1: Gallery *@
        @await Html.PartialAsync(
            "~/Views/SingleProductPage/Sections/_GallerySection.cshtml",
            Model.CurrentPage)

        @* SECTION 2: Summary *@
        @await Html.PartialAsync(
            "~/Views/SingleProductPage/Sections/_SummarySection.cshtml",
            Model.CurrentPage)
    </div>

    @* SECTION 3: Tabs *@
    @await Html.PartialAsync(
        "~/Views/SingleProductPage/Sections/_TabsSection.cshtml",
        Model.CurrentPage)

    @* SECTION 4: Related Products *@
    @await Html.PartialAsync(
        "~/Views/SingleProductPage/Sections/_RelatedSection.cshtml",
        Model.CurrentPage)
</div>