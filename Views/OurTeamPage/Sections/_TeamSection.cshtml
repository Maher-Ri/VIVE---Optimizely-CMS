                      <div class="team-carousel-wrapper style2">
                          <div class="owl-carousel" data-autoplay="0" data-items="4" data-margin="20" data-pagination="0" data-stage-padding="70" data-timer="8000">

                              @foreach (var item in Model.Carousel1Members.FilteredItems)
