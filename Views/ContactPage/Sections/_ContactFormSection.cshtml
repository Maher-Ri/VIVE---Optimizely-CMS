                    <div class="wpcf7 no-js" id="wpcf7-f5-p3374-o1">

                        @* Success Message *@
                        @if (TempData["ContactSuccess"] != null)
                        {
                            <div class="response success" style="display:block;">
                                @TempData["ContactSuccess"]
                            </div>
                        }

                        <form action="@pageUrl"
                              class="wpcf7-form init"
                              method="post">

                            @Html.AntiForgeryToken()
                            <input type="hidden" name="Subject" value="Vive: Contact Page" />

                            <label>Your name
                                <span class="wpcf7-form-control-wrap" data-name="your-name">
                                    <input type="text"
                                           placeholder="Name*"
                                           aria-required="true"
                                           size="43"
                                           name="Name"
                                           required />
                                </span>
                            </label>

                            <label>Your email
                                <span class="wpcf7-form-control-wrap" data-name="your-email">
                                    <input type="email"
                                           placeholder="E-mail address*"
                                           aria-required="true"
                                           size="43"
                                           name="Email"
                                           required />
                                </span>
                            </label>

                            <label>Subject
                                <span class="wpcf7-form-control-wrap" data-name="your-subject">
                                    <input type="text"
                                           placeholder="Subject*"
                                           size="43"
                                           name="Subject"
                                           required />
                                </span>
                            </label>

                            <label>Your message
                                <span class="wpcf7-form-control-wrap" data-name="your-message">
                                    <textarea placeholder="Message*"
                                              rows="9"
                                              cols="40"
                                              name="Message"
                                              required></textarea>
                                </span>
                            </label>

                            <input class="wpcf7-form-control wpcf7-submit"
                                   type="submit"
                                   value="Submit" />

                            <div class="response success" style="display:none;">
                                Thanks. Your message was sent!
                            </div>
                            <div class="response error" style="display:none;">
                                We could not sent your message!
                            </div>

                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

</div>